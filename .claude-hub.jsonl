    67→  .turn-dot.black { background: #222; }\n    68→\n    69→  .new-game-btn {\n    70→    background: #0f3460;\n    71→    color: #e0e0e8;\n    72→    border: 1px solid #1a5276;\n    73→    border-radius: 6px;\n    74→    padding: 0.45rem 1rem;\n    75→    font-size: 0.9rem;\n    76→    font-weight: 600;\n    77→    cursor: pointer;\n    78→    transition: background 0.2s, transform 0.1s;\n    79→    white-space: nowrap;\n    80→  }\n    81→\n    82→  .new-game-btn:hover { background: #1a5276; }\n    83→  .new-game-btn:active { transform: scale(0.97); }\n    84→\n    85→  /* Captured pieces */\n    86→  .captured-row {\n    87→    width: 100%;\n    88→    background: #16213e;\n    89→    border-radius: 6px;\n    90→    padding: 0.4rem 0.75rem;\n    91→    min-height: 2.2rem;\n    92→    display: flex;\n    93→    align-items: center;\n    94→    gap: 0.15rem;\n    95→    box-shadow: 0 1px 6px rgba(0,0,0,.2);\n    96→  }\n    97→\n    98→  .captured-label {\n    99→    color: #666;\n   100→    font-size: 0.75rem;\n   101→    font-weight: 600;\n   102→    text-transform: uppercase;\n   103→    letter-spacing: 0.04em;\n   104→    margin-right: 0.4rem;\n   105→    flex-shrink: 0;\n   106→  }\n   107→\n   108→  .captured-pieces {\n   109→    display: flex;\n   110→    flex-wrap: wrap;\n   111→    gap: 0.1rem;\n   112→    font-size: 1.3rem;\n   113→    line-height: 1;\n   114→  }\n   115→\n   116→  /* Board */\n   117→  .board-container {\n   118→    display: inline-grid;\n   119→    grid-template-columns: 2rem repeat(8, 1fr);\n   120→    grid-template-rows: repeat(8, 1fr) 2rem;\n   121→    width: 100%;\n   122→    aspect-ratio: 1;\n   123→    border: 4px solid #16213e;\n   124→    border-radius: 6px;\n   125→    overflow: hidden;\n   126→    box-shadow: 0 8px 32px rgba(0,0,0,.5);\n   127→  }\n   128→\n   129→  .rank-label {\n   130→    display: flex;\n   131→    align-items: center;\n   132→    justify-content: center;\n   133→    background: #16213e;\n   134→    color: #a0a0b0;\n   135→    font-size: 0.85rem;\n   136→    font-weight: 600;\n   137→    width: 2rem;\n   138→  }\n   139→\n   140→  .file-label {\n   141→    display: flex;\n   142→    align-items: center;\n   143→    justify-content: center;\n   144→    background: #16213e;\n   145→    color: #a0a0b0;\n   146→    font-size: 0.85rem;\n   147→    font-weight: 600;\n   148→    height: 2rem;\n   149→  }\n   150→\n   151→  .corner {\n   152→    background: #16213e;\n   153→  }\n   154→\n   155→  .square {\n   156→    display: flex;\n   157→    align-items: center;\n   158→    justify-content: center;\n   159→    font-size: clamp(1.5rem, 5vw, 3.2rem);\n   160→    cursor: pointer;\n   161→    user-select: none;\n   162→    transition: background-color 0.15s;\n   163→    aspect-ratio: 1;\n   164→    position: relative;\n   165→  }\n   166→\n   167→  .square .piece {\n   168→    transition: opacity 0.15s ease;\n   169→  }\n   170→\n   171→  .square.light { background: #e8dcc8; }\n   172→  .square.dark  { background: #7b6b4f; }\n   173→  .square:hover { filter: brightness(1.12); }\n   174→\n   175→  .square.selected { background: #f6e96b !important; }\n   176→  .square.valid-move::after {\n   177→    content: '';\n   178→    position: absolute;\n   179→    width: 30%;\n   180→    height: 30%;\n   181→    background: rgba(0, 0, 0, 0.25);\n   182→    border-radius: 50%;\n   183→    pointer-events: none;\n   184→  }\n   185→  .square.valid-move.has-enemy::after {\n   186→    width: 85%;\n   187→    height: 85%;\n   188→    background: transparent;\n   189→    border: 5px solid rgba(0, 0, 0, 0.25);\n   190→    border-radius: 50%;\n   191→  }\n   192→\n   193→  .square.last-move {\n   194→    background: rgba(246, 233, 107, 0.35) !important;\n   195→  }\n   196→\n   197→  .square.in-check {\n   198→    background: #e74c3c !important;\n   199→    box-shadow: inset 0 0 12px rgba(0,0,0,.4);\n   200→  }\n   201→\n   202→  /* Move animation */\n   203→  @keyframes pieceAppear {\n   204→    from { transform: scale(0.7); opacity: 0.4; }\n   205→    to { transform: scale(1); opacity: 1; }\n   206→  }\n   207→\n   208→  .square.just-moved .piece {\n   209→    animation: pieceAppear 0.2s ease-out;\n   210→  }\n   211→\n   212→  @media (max-width: 500px) {\n   213→    .status-bar { padding: 0.5rem 0.75rem; }\n   214→    .status-text { font-size: 0.9rem; }\n   215→    .new-game-btn { padding: 0.35rem 0.7rem; font-size: 0.8rem; }\n   216→    .rank-label, .file-label { font-size: 0.7rem; }\n   217→    .rank-label { width: 1.5rem; }\n   218→    .board-container { grid-template-columns: 1.5rem repeat(8, 1fr); }\n   219→  }\n   220→</style>\n   221→</head>\n   222→<body>\n   223→\n   224→<div class=\"game-wrapper\">\n   225→  <div class=\"status-bar\">\n   226→    <div class=\"status-text\" id=\"status\"><span class=\"turn-dot white\"></span>White's turn</div>\n   227→    <button class=\"new-game-btn\" id=\"newGameBtn\">New Game</button>\n   228→  </div>\n   229→\n   230→  <div class=\"captured-row\" id=\"capturedBlack\">\n   231→    <span class=\"captured-label\">Black:</span>\n   232→    <div class=\"captured-pieces\" id=\"capturedBlackPieces\"></div>\n   233→  </div>\n   234→\n   235→  <div class=\"board-container\" id=\"board\"></div>\n   236→\n   237→  <div class=\"captured-row\" id=\"capturedWhite\">\n   238→    <span class=\"captured-label\">White:</span>\n   239→    <div class=\"captured-pieces\" id=\"capturedWhitePieces\"></div>\n   240→  </div>\n   241→</div>\n   242→\n   243→<script>\n   244→const PIECES = {\n   245→  K: { type: 'king',   color: 'white', symbol: '\\u2654' },\n   246→  Q: { type: 'queen',  color: 'white', symbol: '\\u2655' },\n   247→  R: { type: 'rook',   color: 'white', symbol: '\\u2656' },\n   248→  B: { type: 'bishop', color: 'white', symbol: '\\u2657' },\n   249→  N: { type: 'knight', color: 'white', symbol: '\\u2658' },\n   250→  P: { type: 'pawn',   color: 'white', symbol: '\\u2659' },\n   251→  k: { type: 'king',   color: 'black', symbol: '\\u265A' },\n   252→  q: { type: 'queen',  color: 'black', symbol: '\\u265B' },\n   253→  r: { type: 'rook',   color: 'black', symbol: '\\u265C' },\n   254→  b: { type: 'bishop', color: 'black', symbol: '\\u265D' },\n   255→  n: { type: 'knight', color: 'black', symbol: '\\u265E' },\n   256→  p: { type: 'pawn',   color: 'black', symbol: '\\u265F' },\n   257→};\n   258→\n   259→const PIECE_VALUE = { pawn: 1, knight: 3, bishop: 3, rook: 5, queen: 9, king: 0 };\n   260→\n   261→function makePiece(key) {\n   262→  if (!key) return null;\n   263→  const p = PIECES[key];\n   264→  return { type: p.type, color: p.color, symbol: p.symbol };\n   265→}\n   266→\n   267→const INITIAL = [\n   268→  ['r','n','b','q','k','b','n','r'],\n   269→  ['p','p','p','p','p','p','p','p'],\n   270→  ['' ,'' ,'' ,'' ,'' ,'' ,'' ,''],\n   271→  ['' ,'' ,'' ,'' ,'' ,'' ,'' ,''],\n   272→  ['' ,'' ,'' ,'' ,'' ,'' ,'' ,''],\n   273→  ['' ,'' ,'' ,'' ,'' ,'' ,'' ,''],\n   274→  ['P','P','P','P','P','P','P','P'],\n   275→  ['R','N','B','Q','K','B','N','R'],\n   276→];\n   277→\n   278→const FILES = ['a','b','c','d','e','f','g','h'];\n   279→const container = document.getElementById('board');\n   280→const statusEl = document.getElementById('status');\n   281→const capturedWhiteEl = document.getElementById('capturedWhitePieces');\n   282→const capturedBlackEl = document.getElementById('capturedBlackPieces');\n   283→\n   284→let boardState;\n   285→let currentTurn;\n   286→let selectedSquare;\n   287→let validMoves;\n   288→let gameOver;\n   289→let capturedWhite; // pieces captured BY white (black pieces)\n   290→let capturedBlack; // pieces captured BY black (white pieces)\n   291→let lastMove;      // { fromRow, fromCol, toRow, toCol }\n   292→\n   293→function initGameState() {\n   294→  boardState = INITIAL.map(row => row.map(makePiece));\n   295→  currentTurn = 'white';\n   296→  selectedSquare = null;\n   297→  validMoves = [];\n   298→  gameOver = false;\n   299→  capturedWhite = [];\n   300→  capturedBlack = [];\n   301→  lastMove = null;\n   302→}\n   303→\n   304→function inBounds(r, c) {\n   305→  return r >= 0 && r < 8 && c >= 0 && c < 8;\n   306→}\n   307→\n   308→function slidingMoves(row, col, directions) {\n   309→  const piece = boardState[row][col];\n   310→  const moves = [];\n   311→  for (const [dr, dc] of directions) {\n   312→    let r = row + dr, c = col + dc;\n   313→    while (inBounds(r, c)) {\n   314→      const target = boardState[r][c];\n   315→      if (!target) {\n   316→        moves.push({ row: r, col: c });\n   317→      } else {\n   318→        if (target.color !== piece.color) moves.push({ row: r, col: c });\n   319→        break;\n   320→      }\n   321→      r += dr;\n   322→      c += dc;\n   323→    }\n   324→  }\n   325→  return moves;\n   326→}\n   327→\n   328→function getValidMoves(piece, row, col) {\n   329→  const moves = [];\n   330→\n   331→  if (piece.type === 'pawn') {\n   332→    const dir = piece.color === 'white' ? -1 : 1;\n   333→    const startRow = piece.color === 'white' ? 6 : 1;\n   334→    if (inBounds(row + dir, col) && !boardState[row + dir][col]) {\n   335→      moves.push({ row: row + dir, col });\n   336→      if (row === startRow && !boardState[row + 2 * dir][col]) {\n   337→        moves.push({ row: row + 2 * dir, col });\n   338→      }\n   339→    }\n   340→    for (const dc of [-1, 1]) {\n   341→      const nr = row + dir, nc = col + dc;\n   342→      if (inBounds(nr, nc) && boardState[nr][nc] && boardState[nr][nc].color !== piece.color) {\n   343→        moves.push({ row: nr, col: nc });\n   344→      }\n   345→    }\n   346→  }\n   347→\n   348→  if (piece.type === 'rook' || piece.type === 'queen') {\n   349→    moves.push(...slidingMoves(row, col, [[1,0],[-1,0],[0,1],[0,-1]]));\n   350→  }\n   351→\n   352→  if (piece.type === 'bishop' || piece.type === 'queen') {\n   353→    moves.push(...slidingMoves(row, col, [[1,1],[1,-1],[-1,1],[-1,-1]]));\n   354→  }\n   355→\n   356→  if (piece.type === 'knight') {\n   357→    for (const [dr, dc] of [[2,1],[2,-1],[-2,1],[-2,-1],[1,2],[1,-2],[-1,2],[-1,-2]]) {\n   358→      const nr = row + dr, nc = col + dc;\n   359→      if (inBounds(nr, nc)) {\n   360→        const target = boardState[nr][nc];\n   361→        if (!target || target.color !== piece.color) moves.push({ row: nr, col: nc });\n   362→      }\n   363→    }\n   364→  }\n   365→\n   366→  if (piece.type === 'king') {\n   367→    for (let dr = -1; dr <= 1; dr++) {\n   368→      for (let dc = -1; dc <= 1; dc++) {\n   369→        if (dr === 0 && dc === 0) continue;\n   370→        const nr = row + dr, nc = col + dc;\n   371→        if (inBounds(nr, nc)) {\n   372→          const target = boardState[nr][nc];\n   373→          if (!target || target.color !== piece.color) moves.push({ row: nr, col: nc });\n   374→        }\n   375→      }\n   376→    }\n   377→  }\n   378→\n   379→  return moves;\n   380→}\n   381→\n   382→function findKing(color) {\n   383→  for (let r = 0; r < 8; r++) {\n   384→    for (let c = 0; c < 8; c++) {\n   385→      const p = boardState[r][c];\n   386→      if (p && p.type === 'king' && p.color === color) return { row: r, col: c };\n   387→    }\n   388→  }\n   389→  return null;\n   390→}\n   391→\n   392→function isKingInCheck(color, board) {\n   393→  let kingRow = -1, kingCol = -1;\n   394→  for (let r = 0; r < 8; r++) {\n   395→    for (let c = 0; c < 8; c++) {\n   396→      const p = board[r][c];\n   397→      if (p && p.type === 'king' && p.color === color) {\n   398→        kingRow = r; kingCol = c; break;\n   399→      }\n   400→    }\n   401→    if (kingRow >= 0) break;\n   402→  }\n   403→\n   404→  const enemy = color === 'white' ? 'black' : 'white';\n   405→\n   406→  for (let r = 0; r < 8; r++) {\n   407→    for (let c = 0; c < 8; c++) {\n   408→      const p = board[r][c];\n   409→      if (!p || p.color !== enemy) continue;\n   410→\n   411→      if (p.type === 'pawn') {\n   412→        const dir = p.color === 'white' ? -1 : 1;\n   413→        if (r + dir === kingRow && (c - 1 === kingCol || c + 1 === kingCol)) return true;\n   414→      } else if (p.type === 'knight') {\n   415→        for (const [dr, dc] of [[2,1],[2,-1],[-2,1],[-2,-1],[1,2],[1,-2],[-1,2],[-1,-2]]) {\n   416→          if (r + dr === kingRow && c + dc === kingCol) return true;\n   417→        }\n   418→      } else if (p.type === 'king') {\n   419→        if (Math.abs(r - kingRow) <= 1 && Math.abs(c - kingCol) <= 1) return true;\n   420→      } else {\n   421→        let dirs = [];\n   422→        if (p.type === 'rook' || p.type === 'queen') dirs.push([1,0],[-1,0],[0,1],[0,-1]);\n   423→        if (p.type === 'bishop' || p.type === 'queen') dirs.push([1,1],[1,-1],[-1,1],[-1,-1]);\n   424→        for (const [dr, dc] of dirs) {\n   425→          let sr = r + dr, sc = c + dc;\n   426→          while (sr >= 0 && sr < 8 && sc >= 0 && sc < 8) {\n   427→            if (sr === kingRow && sc === kingCol) return true;\n   428→            if (board[sr][sc]) break;\n   429→            sr += dr; sc += dc;\n   430→          }\n   431→        }\n   432→      }\n   433→    }\n   434→  }\n   435→  return false;\n   436→}\n   437→\n   438→function getLegalMoves(piece, row, col) {\n   439→  const pseudo = getValidMoves(piece, row, col);\n   440→  return pseudo.filter(m => {\n   441→    const saved = boardState[m.row][m.col];\n   442→    boardState[m.row][m.col] = boardState[row][col];\n   443→    boardState[row][col] = null;\n   444→    const inCheck = isKingInCheck(piece.color, boardState);\n   445→    boardState[row][col] = boardState[m.row][m.col];\n   446→    boardState[m.row][m.col] = saved;\n   447→    return !inCheck;\n   448→  });\n   449→}\n   450→\n   451→function hasAnyLegalMoves(color) {\n   452→  for (let r = 0; r < 8; r++) {\n   453→    for (let c = 0; c < 8; c++) {\n   454→      const p = boardState[r][c];\n   455→      if (p && p.color === color && getLegalMoves(p, r, c).length > 0) return true;\n   456→    }\n   457→  }\n   458→  return false;\n   459→}\n   460→\n   461→function getSquareEl(row, col) {\n   462→  return container.querySelector(`.square[data-row=\"${row}\"][data-col=\"${col}\"]`);\n   463→}\n   464→\n   465→function updateStatus() {\n   466→  const dot = currentTurn === 'white'\n   467→    ? '<span class=\"turn-dot white\"></span>'\n   468→    : '<span class=\"turn-dot black\"></span>';\n   469→  const name = currentTurn === 'white' ? 'White' : 'Black';\n   470→\n   471→  const inCheck = isKingInCheck(currentTurn, boardState);\n   472→  const hasLegal = hasAnyLegalMoves(currentTurn);\n   473→\n   474→  // Highlight king in check\n   475→  container.querySelectorAll('.square.in-check').forEach(sq => sq.classList.remove('in-check'));\n   476→  for (const color of ['white', 'black']) {\n   477→    if (isKingInCheck(color, boardState)) {\n   478→      const king = findKing(color);\n   479→      if (king) getSquareEl(king.row, king.col).classList.add('in-check');\n   480→    }\n   481→  }\n   482→\n   483→  if (!hasLegal) {\n   484→    gameOver = true;\n   485→    if (inCheck) {\n   486→      const winner = currentTurn === 'white' ? 'Black' : 'White';\n   487→      statusEl.innerHTML = `<span class=\"result\">Checkmate! ${winner} wins!</span>`;\n   488→    } else {\n   489→      statusEl.innerHTML = `<span class=\"result\">Stalemate &mdash; draw!</span>`;\n   490→    }\n   491→  } else if (inCheck) {\n   492→    statusEl.innerHTML = `${dot}${name}'s turn &mdash; <span class=\"check-warning\">Check!</span>`;\n   493→  } else {\n   494→    statusEl.innerHTML = `${dot}${name}'s turn`;\n   495→  }\n   496→}\n   497→\n   498→function updateCaptured() {\n   499→  const sortFn = (a, b) => PIECE_VALUE[b.type] - PIECE_VALUE[a.type];\n   500→  capturedWhite.sort(sortFn);\n   501→  capturedBlack.sort(sortFn);\n   502→  capturedWhiteEl.textContent = capturedWhite.map(p => p.symbol).join('');\n   503→  capturedBlackEl.textContent = capturedBlack.map(p => p.symbol).join('');\n   504→}\n   505→\n   506→function highlightLastMove() {\n   507→  container.querySelectorAll('.square.last-move, .square.just-moved').forEach(sq => {\n   508→    sq.classList.remove('last-move', 'just-moved');\n   509→  });\n   510→  if (lastMove) {\n   511→    getSquareEl(lastMove.fromRow, lastMove.fromCol).classList.add('last-move');\n   512→    const toEl = getSquareEl(lastMove.toRow, lastMove.toCol);\n   513→    toEl.classList.add('last-move', 'just-moved');\n   514→  }\n   515→}\n   516→\n   517→function clearHighlights() {\n   518→  container.querySelectorAll('.square.selected, .square.valid-move').forEach(sq => {\n   519→    sq.classList.remove('selected', 'valid-move', 'has-enemy');\n   520→  });\n   521→}\n   522→\n   523→function applyHighlights() {\n   524→  if (!selectedSquare) return;\n   525→  getSquareEl(selectedSquare.row, selectedSquare.col).classList.add('selected');\n   526→  for (const m of validMoves) {\n   527→    const el = getSquareEl(m.row, m.col);\n   528→    el.classList.add('valid-move');\n   529→    if (boardState[m.row][m.col]) el.classList.add('has-enemy');\n   530→  }\n   531→}\n   532→\n   533→function movePiece(fromRow, fromCol, toRow, toCol) {\n   534→  const captured = boardState[toRow][toCol];\n   535→  if (captured) {\n   536→    if (captured.color === 'white') {\n   537→      capturedBlack.push(captured);\n   538→    } else {\n   539→      capturedWhite.push(captured);\n   540→    }\n   541→    updateCaptured();\n   542→  }\n   543→\n   544→  boardState[toRow][toCol] = boardState[fromRow][fromCol];\n   545→  boardState[fromRow][fromCol] = null;\n   546→\n   547→  // Update DOM\n   548→  const fromEl = getSquareEl(fromRow, fromCol);\n   549→  const toEl = getSquareEl(toRow, toCol);\n   550→  fromEl.textContent = '';\n   551→  toEl.textContent = boardState[toRow][toCol].symbol;\n   552→\n   553→  lastMove = { fromRow, fromCol, toRow, toCol };\n   554→  highlightLastMove();\n   555→\n   556→  // Switch turn\n   557→  currentTurn = currentTurn === 'white' ? 'black' : 'white';\n   558→  updateStatus();\n   559→}\n   560→\n   561→function handleClick(row, col) {\n   562→  if (gameOver) return;\n   563→  const piece = boardState[row][col];\n   564→\n   565→  if (selectedSquare) {\n   566→    const isValid = validMoves.some(m => m.row === row && m.col === col);\n   567→    if (isValid) {\n   568→      clearHighlights();\n   569→      movePiece(selectedSquare.row, selectedSquare.col, row, col);\n   570→      selectedSquare = null;\n   571→      validMoves = [];\n   572→      return;\n   573→    }\n   574→\n   575→    const prevRow = selectedSquare.row;\n   576→    const prevCol = selectedSquare.col;\n   577→    clearHighlights();\n   578→    selectedSquare = null;\n   579→    validMoves = [];\n   580→\n   581→    if (piece && piece.color === currentTurn && !(row === prevRow && col === prevCol)) {\n   582→      // fall through to selection below\n   583→    } else {\n   584→      return;\n   585→    }\n   586→  }\n   587→\n   588→  if (piece && piece.color === currentTurn) {\n   589→    selectedSquare = { row, col };\n   590→    validMoves = getLegalMoves(piece, row, col);\n   591→    applyHighlights();\n   592→  }\n   593→}\n   594→\n   595→function buildBoard() {\n   596→  container.innerHTML = '';\n   597→  for (let row = 0; row < 8; row++) {\n   598→    const rl = document.createElement('div');\n   599→    rl.className = 'rank-label';\n   600→    rl.textContent = 8 - row;\n   601→    container.appendChild(rl);\n   602→\n   603→    for (let col = 0; col < 8; col++) {\n   604→      const sq = document.createElement('div');\n   605→      const isLight = (row + col) % 2 === 0;\n   606→      sq.className = 'square ' + (isLight ? 'light' : 'dark');\n   607→      sq.dataset.row = row;\n   608→      sq.dataset.col = col;\n   609→\n   610→      const piece = boardState[row][col];\n   611→      if (piece) sq.textContent = piece.symbol;\n   612→\n   613→      sq.addEventListener('click', () => handleClick(row, col));\n   614→      container.appendChild(sq);\n   615→    }\n   616→  }\n   617→\n   618→  const corner = document.createElement('div');\n   619→  corner.className = 'corner';\n   620→  container.appendChild(corner);\n   621→\n   622→  for (const f of FILES) {\n   623→    const fl = document.createElement('div');\n   624→    fl.className = 'file-label';\n   625→    fl.textContent = f;\n   626→    container.appendChild(fl);\n   627→  }\n   628→}\n   629→\n   630→function newGame() {\n   631→  initGameState();\n   632→  buildBoard();\n   633→  updateCaptured();\n   634→  updateStatus();\n   635→}\n   636→\n   637→// New Game button\n   638→document.getElementById('newGameBtn').addEventListener('click', newGame);\n   639→\n   640→// Initial setup\n   641→newGame();\n   642→</script>\n   643→</body>\n   644→</html>\n   645→"}]},"parent_tool_use_id":null,"session_id":"02c20103-6292-43ed-a4a2-eedf0faac846","uuid":"9f25bb95-3b93-406f-a286-b26115828553","tool_use_result":{"type":"text","file":{"filePath":"/data/clones/8f966736-389/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Chess Demo</title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    background: #1a1a2e;\n    font-family: system-ui, -apple-system, sans-serif;\n    padding: 1rem;\n  }\n\n  .game-wrapper {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 0.75rem;\n    width: min(90vw, 90vh, 600px);\n  }\n\n  /* Status bar */\n  .status-bar {\n    width: 100%;\n    background: #16213e;\n    border-radius: 8px;\n    padding: 0.75rem 1.25rem;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    box-shadow: 0 2px 12px rgba(0,0,0,.3);\n  }\n\n  .status-text {\n    color: #e0e0e8;\n    font-size: 1.05rem;\n    font-weight: 600;\n  }\n\n  .status-text .check-warning {\n    color: #e74c3c;\n    font-weight: 700;\n  }\n\n  .status-text .result {\n    color: #f6e96b;\n  }\n\n  .turn-dot {\n    display: inline-block;\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    margin-right: 0.5rem;\n    vertical-align: middle;\n    border: 2px solid #555;\n  }\n\n  .turn-dot.white { background: #fff; }\n  .turn-dot.black { background: #222; }\n\n  .new-game-btn {\n    background: #0f3460;\n    color: #e0e0e8;\n    border: 1px solid #1a5276;\n    border-radius: 6px;\n    padding: 0.45rem 1rem;\n    font-size: 0.9rem;\n    font-weight: 600;\n    cursor: pointer;\n    transition: background 0.2s, transform 0.1s;\n    white-space: nowrap;\n  }\n\n  .new-game-btn:hover { background: #1a5276; }\n  .new-game-btn:active { transform: scale(0.97); }\n\n  /* Captured pieces */\n  .captured-row {\n    width: 100%;\n    background: #16213e;\n    border-radius: 6px;\n    padding: 0.4rem 0.75rem;\n    min-height: 2.2rem;\n    display: flex;\n    align-items: center;\n    gap: 0.15rem;\n    box-shadow: 0 1px 6px rgba(0,0,0,.2);\n  }\n\n  .captured-label {\n    color: #666;\n    font-size: 0.75rem;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n    margin-right: 0.4rem;\n    flex-shrink: 0;\n  }\n\n  .captured-pieces {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 0.1rem;\n    font-size: 1.3rem;\n    line-height: 1;\n  }\n\n  /* Board */\n  .board-container {\n    display: inline-grid;\n    grid-template-columns: 2rem repeat(8, 1fr);\n    grid-template-rows: repeat(8, 1fr) 2rem;\n    width: 100%;\n    aspect-ratio: 1;\n    border: 4px solid #16213e;\n    border-radius: 6px;\n    overflow: hidden;\n    box-shadow: 0 8px 32px rgba(0,0,0,.5);\n  }\n\n  .rank-label {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: #16213e;\n    color: #a0a0b0;\n    font-size: 0.85rem;\n    font-weight: 600;\n    width: 2rem;\n  }\n\n  .file-label {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: #16213e;\n    color: #a0a0b0;\n    font-size: 0.85rem;\n    font-weight: 600;\n    height: 2rem;\n  }\n\n  .corner {\n    background: #16213e;\n  }\n\n  .square {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: clamp(1.5rem, 5vw, 3.2rem);\n    cursor: pointer;\n    user-select: none;\n    transition: background-color 0.15s;\n    aspect-ratio: 1;\n    position: relative;\n  }\n\n  .square .piece {\n    transition: opacity 0.15s ease;\n  }\n\n  .square.light { background: #e8dcc8; }\n  .square.dark  { background: #7b6b4f; }\n  .square:hover { filter: brightness(1.12); }\n\n  .square.selected { background: #f6e96b !important; }\n  .square.valid-move::after {\n    content: '';\n    position: absolute;\n    width: 30%;\n    height: 30%;\n    background: rgba(0, 0, 0, 0.25);\n    border-radius: 50%;\n    pointer-events: none;\n  }\n  .square.valid-move.has-enemy::after {\n    width: 85%;\n    height: 85%;\n    background: transparent;\n    border: 5px solid rgba(0, 0, 0, 0.25);\n    border-radius: 50%;\n  }\n\n  .square.last-move {\n    background: rgba(246, 233, 107, 0.35) !important;\n  }\n\n  .square.in-check {\n    background: #e74c3c !important;\n    box-shadow: inset 0 0 12px rgba(0,0,0,.4);\n  }\n\n  /* Move animation */\n  @keyframes pieceAppear {\n    from { transform: scale(0.7); opacity: 0.4; }\n    to { transform: scale(1); opacity: 1; }\n  }\n\n  .square.just-moved .piece {\n    animation: pieceAppear 0.2s ease-out;\n  }\n\n  @media (max-width: 500px) {\n    .status-bar { padding: 0.5rem 0.75rem; }\n    .status-text { font-size: 0.9rem; }\n    .new-game-btn { padding: 0.35rem 0.7rem; font-size: 0.8rem; }\n    .rank-label, .file-label { font-size: 0.7rem; }\n    .rank-label { width: 1.5rem; }\n    .board-container { grid-template-columns: 1.5rem repeat(8, 1fr); }\n  }\n</style>\n</head>\n<body>\n\n<div class=\"game-wrapper\">\n  <div class=\"status-bar\">\n    <div class=\"status-text\" id=\"status\"><span class=\"turn-dot white\"></span>White's turn</div>\n    <button class=\"new-game-btn\" id=\"newGameBtn\">New Game</button>\n  </div>\n\n  <div class=\"captured-row\" id=\"capturedBlack\">\n    <span class=\"captured-label\">Black:</span>\n    <div class=\"captured-pieces\" id=\"capturedBlackPieces\"></div>\n  </div>\n\n  <div class=\"board-container\" id=\"board\"></div>\n\n  <div class=\"captured-row\" id=\"capturedWhite\">\n    <span class=\"captured-label\">White:</span>\n    <div class=\"captured-pieces\" id=\"capturedWhitePieces\"></div>\n  </div>\n</div>\n\n<script>\nconst PIECES = {\n  K: { type: 'king',   color: 'white', symbol: '\\u2654' },\n  Q: { type: 'queen',  color: 'white', symbol: '\\u2655' },\n  R: { type: 'rook',   color: 'white', symbol: '\\u2656' },\n  B: { type: 'bishop', color: 'white', symbol: '\\u2657' },\n  N: { type: 'knight', color: 'white', symbol: '\\u2658' },\n  P: { type: 'pawn',   color: 'white', symbol: '\\u2659' },\n  k: { type: 'king',   color: 'black', symbol: '\\u265A' },\n  q: { type: 'queen',  color: 'black', symbol: '\\u265B' },\n  r: { type: 'rook',   color: 'black', symbol: '\\u265C' },\n  b: { type: 'bishop', color: 'black', symbol: '\\u265D' },\n  n: { type: 'knight', color: 'black', symbol: '\\u265E' },\n  p: { type: 'pawn',   color: 'black', symbol: '\\u265F' },\n};\n\nconst PIECE_VALUE = { pawn: 1, knight: 3, bishop: 3, rook: 5, queen: 9, king: 0 };\n\nfunction makePiece(key) {\n  if (!key) return null;\n  const p = PIECES[key];\n  return { type: p.type, color: p.color, symbol: p.symbol };\n}\n\nconst INITIAL = [\n  ['r','n','b','q','k','b','n','r'],\n  ['p','p','p','p','p','p','p','p'],\n  ['' ,'' ,'' ,'' ,'' ,'' ,'' ,''],\n  ['' ,'' ,'' ,'' ,'' ,'' ,'' ,''],\n  ['' ,'' ,'' ,'' ,'' ,'' ,'' ,''],\n  ['' ,'' ,'' ,'' ,'' ,'' ,'' ,''],\n  ['P','P','P','P','P','P','P','P'],\n  ['R','N','B','Q','K','B','N','R'],\n];\n\nconst FILES = ['a','b','c','d','e','f','g','h'];\nconst container = document.getElementById('board');\nconst statusEl = document.getElementById('status');\nconst capturedWhiteEl = document.getElementById('capturedWhitePieces');\nconst capturedBlackEl = document.getElementById('capturedBlackPieces');\n\nlet boardState;\nlet currentTurn;\nlet selectedSquare;\nlet validMoves;\nlet gameOver;\nlet capturedWhite; // pieces captured BY white (black pieces)\nlet capturedBlack; // pieces captured BY black (white pieces)\nlet lastMove;      // { fromRow, fromCol, toRow, toCol }\n\nfunction initGameState() {\n  boardState = INITIAL.map(row => row.map(makePiece));\n  currentTurn = 'white';\n  selectedSquare = null;\n  validMoves = [];\n  gameOver = false;\n  capturedWhite = [];\n  capturedBlack = [];\n  lastMove = null;\n}\n\nfunction inBounds(r, c) {\n  return r >= 0 && r < 8 && c >= 0 && c < 8;\n}\n\nfunction slidingMoves(row, col, directions) {\n  const piece = boardState[row][col];\n  const moves = [];\n  for (const [dr, dc] of directions) {\n    let r = row + dr, c = col + dc;\n    while (inBounds(r, c)) {\n      const target = boardState[r][c];\n      if (!target) {\n        moves.push({ row: r, col: c });\n      } else {\n        if (target.color !== piece.color) moves.push({ row: r, col: c });\n        break;\n      }\n      r += dr;\n      c += dc;\n    }\n  }\n  return moves;\n}\n\nfunction getValidMoves(piece, row, col) {\n  const moves = [];\n\n  if (piece.type === 'pawn') {\n    const dir = piece.color === 'white' ? -1 : 1;\n    const startRow = piece.color === 'white' ? 6 : 1;\n    if (inBounds(row + dir, col) && !boardState[row + dir][col]) {\n      moves.push({ row: row + dir, col });\n      if (row === startRow && !boardState[row + 2 * dir][col]) {\n        moves.push({ row: row + 2 * dir, col });\n      }\n    }\n    for (const dc of [-1, 1]) {\n      const nr = row + dir, nc = col + dc;\n      if (inBounds(nr, nc) && boardState[nr][nc] && boardState[nr][nc].color !== piece.color) {\n        moves.push({ row: nr, col: nc });\n      }\n    }\n  }\n\n  if (piece.type === 'rook' || piece.type === 'queen') {\n    moves.push(...slidingMoves(row, col, [[1,0],[-1,0],[0,1],[0,-1]]));\n  }\n\n  if (piece.type === 'bishop' || piece.type === 'queen') {\n    moves.push(...slidingMoves(row, col, [[1,1],[1,-1],[-1,1],[-1,-1]]));\n  }\n\n  if (piece.type === 'knight') {\n    for (const [dr, dc] of [[2,1],[2,-1],[-2,1],[-2,-1],[1,2],[1,-2],[-1,2],[-1,-2]]) {\n      const nr = row + dr, nc = col + dc;\n      if (inBounds(nr, nc)) {\n        const target = boardState[nr][nc];\n        if (!target || target.color !== piece.color) moves.push({ row: nr, col: nc });\n      }\n    }\n  }\n\n  if (piece.type === 'king') {\n    for (let dr = -1; dr <= 1; dr++) {\n      for (let dc = -1; dc <= 1; dc++) {\n        if (dr === 0 && dc === 0) continue;\n        const nr = row + dr, nc = col + dc;\n        if (inBounds(nr, nc)) {\n          const target = boardState[nr][nc];\n          if (!target || target.color !== piece.color) moves.push({ row: nr, col: nc });\n        }\n      }\n    }\n  }\n\n  return moves;\n}\n\nfunction findKing(color) {\n  for (let r = 0; r < 8; r++) {\n    for (let c = 0; c < 8; c++) {\n      const p = boardState[r][c];\n      if (p && p.type === 'king' && p.color === color) return { row: r, col: c };\n    }\n  }\n  return null;\n}\n\nfunction isKingInCheck(color, board) {\n  let kingRow = -1, kingCol = -1;\n  for (let r = 0; r < 8; r++) {\n    for (let c = 0; c < 8; c++) {\n      const p = board[r][c];\n      if (p && p.type === 'king' && p.color === color) {\n        kingRow = r; kingCol = c; break;\n      }\n    }\n    if (kingRow >= 0) break;\n  }\n\n  const enemy = color === 'white' ? 'black' : 'white';\n\n  for (let r = 0; r < 8; r++) {\n    for (let c = 0; c < 8; c++) {\n      const p = board[r][c];\n      if (!p || p.color !== enemy) continue;\n\n      if (p.type === 'pawn') {\n        const dir = p.color === 'white' ? -1 : 1;\n        if (r + dir === kingRow && (c - 1 === kingCol || c + 1 === kingCol)) return true;\n      } else if (p.type === 'knight') {\n        for (const [dr, dc] of [[2,1],[2,-1],[-2,1],[-2,-1],[1,2],[1,-2],[-1,2],[-1,-2]]) {\n          if (r + dr === kingRow && c + dc === kingCol) return true;\n        }\n      } else if (p.type === 'king') {\n        if (Math.abs(r - kingRow) <= 1 && Math.abs(c - kingCol) <= 1) return true;\n      } else {\n        let dirs = [];\n        if (p.type === 'rook' || p.type === 'queen') dirs.push([1,0],[-1,0],[0,1],[0,-1]);\n        if (p.type === 'bishop' || p.type === 'queen') dirs.push([1,1],[1,-1],[-1,1],[-1,-1]);\n        for (const [dr, dc] of dirs) {\n          let sr = r + dr, sc = c + dc;\n          while (sr >= 0 && sr < 8 && sc >= 0 && sc < 8) {\n            if (sr === kingRow && sc === kingCol) return true;\n            if (board[sr][sc]) break;\n            sr += dr; sc += dc;\n          }\n        }\n      }\n    }\n  }\n  return false;\n}\n\nfunction getLegalMoves(piece, row, col) {\n  const pseudo = getValidMoves(piece, row, col);\n  return pseudo.filter(m => {\n    const saved = boardState[m.row][m.col];\n    boardState[m.row][m.col] = boardState[row][col];\n    boardState[row][col] = null;\n    const inCheck = isKingInCheck(piece.color, boardState);\n    boardState[row][col] = boardState[m.row][m.col];\n    boardState[m.row][m.col] = saved;\n    return !inCheck;\n  });\n}\n\nfunction hasAnyLegalMoves(color) {\n  for (let r = 0; r < 8; r++) {\n    for (let c = 0; c < 8; c++) {\n      const p = boardState[r][c];\n      if (p && p.color === color && getLegalMoves(p, r, c).length > 0) return true;\n    }\n  }\n  return false;\n}\n\nfunction getSquareEl(row, col) {\n  return container.querySelector(`.square[data-row=\"${row}\"][data-col=\"${col}\"]`);\n}\n\nfunction updateStatus() {\n  const dot = currentTurn === 'white'\n    ? '<span class=\"turn-dot white\"></span>'\n    : '<span class=\"turn-dot black\"></span>';\n  const name = currentTurn === 'white' ? 'White' : 'Black';\n\n  const inCheck = isKingInCheck(currentTurn, boardState);\n  const hasLegal = hasAnyLegalMoves(currentTurn);\n\n  // Highlight king in check\n  container.querySelectorAll('.square.in-check').forEach(sq => sq.classList.remove('in-check'));\n  for (const color of ['white', 'black']) {\n    if (isKingInCheck(color, boardState)) {\n      const king = findKing(color);\n      if (king) getSquareEl(king.row, king.col).classList.add('in-check');\n    }\n  }\n\n  if (!hasLegal) {\n    gameOver = true;\n    if (inCheck) {\n      const winner = currentTurn === 'white' ? 'Black' : 'White';\n      statusEl.innerHTML = `<span class=\"result\">Checkmate! ${winner} wins!</span>`;\n    } else {\n      statusEl.innerHTML = `<span class=\"result\">Stalemate &mdash; draw!</span>`;\n    }\n  } else if (inCheck) {\n    statusEl.innerHTML = `${dot}${name}'s turn &mdash; <span class=\"check-warning\">Check!</span>`;\n  } else {\n    statusEl.innerHTML = `${dot}${name}'s turn`;\n  }\n}\n\nfunction updateCaptured() {\n  const sortFn = (a, b) => PIECE_VALUE[b.type] - PIECE_VALUE[a.type];\n  capturedWhite.sort(sortFn);\n  capturedBlack.sort(sortFn);\n  capturedWhiteEl.textContent = capturedWhite.map(p => p.symbol).join('');\n  capturedBlackEl.textContent = capturedBlack.map(p => p.symbol).join('');\n}\n\nfunction highlightLastMove() {\n  container.querySelectorAll('.square.last-move, .square.just-moved').forEach(sq => {\n    sq.classList.remove('last-move', 'just-moved');\n  });\n  if (lastMove) {\n    getSquareEl(lastMove.fromRow, lastMove.fromCol).classList.add('last-move');\n    const toEl = getSquareEl(lastMove.toRow, lastMove.toCol);\n    toEl.classList.add('last-move', 'just-moved');\n  }\n}\n\nfunction clearHighlights() {\n  container.querySelectorAll('.square.selected, .square.valid-move').forEach(sq => {\n    sq.classList.remove('selected', 'valid-move', 'has-enemy');\n  });\n}\n\nfunction applyHighlights() {\n  if (!selectedSquare) return;\n  getSquareEl(selectedSquare.row, selectedSquare.col).classList.add('selected');\n  for (const m of validMoves) {\n    const el = getSquareEl(m.row, m.col);\n    el.classList.add('valid-move');\n    if (boardState[m.row][m.col]) el.classList.add('has-enemy');\n  }\n}\n\nfunction movePiece(fromRow, fromCol, toRow, toCol) {\n  const captured = boardState[toRow][toCol];\n  if (captured) {\n    if (captured.color === 'white') {\n      capturedBlack.push(captured);\n    } else {\n      capturedWhite.push(captured);\n    }\n    updateCaptured();\n  }\n\n  boardState[toRow][toCol] = boardState[fromRow][fromCol];\n  boardState[fromRow][fromCol] = null;\n\n  // Update DOM\n  const fromEl = getSquareEl(fromRow, fromCol);\n  const toEl = getSquareEl(toRow, toCol);\n  fromEl.textContent = '';\n  toEl.textContent = boardState[toRow][toCol].symbol;\n\n  lastMove = { fromRow, fromCol, toRow, toCol };\n  highlightLastMove();\n\n  // Switch turn\n  currentTurn = currentTurn === 'white' ? 'black' : 'white';\n  updateStatus();\n}\n\nfunction handleClick(row, col) {\n  if (gameOver) return;\n  const piece = boardState[row][col];\n\n  if (selectedSquare) {\n    const isValid = validMoves.some(m => m.row === row && m.col === col);\n    if (isValid) {\n      clearHighlights();\n      movePiece(selectedSquare.row, selectedSquare.col, row, col);\n      selectedSquare = null;\n      validMoves = [];\n      return;\n    }\n\n    const prevRow = selectedSquare.row;\n    const prevCol = selectedSquare.col;\n    clearHighlights();\n    selectedSquare = null;\n    validMoves = [];\n\n    if (piece && piece.color === currentTurn && !(row === prevRow && col === prevCol)) {\n      // fall through to selection below\n    } else {\n      return;\n    }\n  }\n\n  if (piece && piece.color === currentTurn) {\n    selectedSquare = { row, col };\n    validMoves = getLegalMoves(piece, row, col);\n    applyHighlights();\n  }\n}\n\nfunction buildBoard() {\n  container.innerHTML = '';\n  for (let row = 0; row < 8; row++) {\n    const rl = document.createElement('div');\n    rl.className = 'rank-label';\n    rl.textContent = 8 - row;\n    container.appendChild(rl);\n\n    for (let col = 0; col < 8; col++) {\n      const sq = document.createElement('div');\n      const isLight = (row + col) % 2 === 0;\n      sq.className = 'square ' + (isLight ? 'light' : 'dark');\n      sq.dataset.row = row;\n      sq.dataset.col = col;\n\n      const piece = boardState[row][col];\n      if (piece) sq.textContent = piece.symbol;\n\n      sq.addEventListener('click', () => handleClick(row, col));\n      container.appendChild(sq);\n    }\n  }\n\n  const corner = document.createElement('div');\n  corner.className = 'corner';\n  container.appendChild(corner);\n\n  for (const f of FILES) {\n    const fl = document.createElement('div');\n    fl.className = 'file-label';\n    fl.textContent = f;\n    container.appendChild(fl);\n  }\n}\n\nfunction newGame() {\n  initGameState();\n  buildBoard();\n  updateCaptured();\n  updateStatus();\n}\n\n// New Game button\ndocument.getElementById('newGameBtn').addEventListener('click', newGame);\n\n// Initial setup\nnewGame();\n</script>\n</body>\n</html>\n","numLines":645,"startLine":1,"totalLines":645}}}
